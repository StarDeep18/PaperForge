# ========================
# PaperForge Environment
# ========================

# Application
APP_NAME=PaperForge
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/paperforge.db

# Vector Database
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=paperforge_chunks

# Google Gemini
GOOGLE_API_KEY=your-google-api-key
LLM_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=text-embedding-004

# Document Processing
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=.pdf,.docx,.txt

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50
PARENT_CHUNK_SIZE=1500
PARENT_CHUNK_OVERLAP=150

# Retrieval
TOP_K_RESULTS=8
SIMILARITY_THRESHOLD=0.3
